{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harness.study/schemas/feature-list.schema.json",
  "title": "Harness Feature State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "mode",
    "features"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.1.0"
    },
    "mode": {
      "type": "string",
      "enum": [
        "serial",
        "parallel"
      ]
    },
    "features": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/feature"
      }
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "steps"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "command",
            "manual"
          ]
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "summary"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "passed",
            "failed",
            "blocked"
          ]
        },
        "summary": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "verificationStep": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "feature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "behavior",
        "branch",
        "dependencies",
        "status",
        "verification",
        "evidence"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._-]*$"
        },
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "behavior": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "branch": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "dependencies": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "status": {
          "type": "string",
          "enum": [
            "not-started",
            "next",
            "in-progress",
            "blocked",
            "done"
          ]
        },
        "verification": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/verification"
            }
          ]
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "not": {
                  "const": "done"
                }
              }
            }
          },
          "then": {
            "properties": {
              "branch": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      ]
    }
  }
}
